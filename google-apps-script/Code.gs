function toNumber(value){if(value===null||value===undefined||value==="")return 0;return Number(String(value).replace(",","."))}
function ensureSheet(){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Einträge");if(!sheet)sheet=SpreadsheetApp.getActiveSpreadsheet().insertSheet("Einträge");if(sheet.getLastRow()===0){sheet.appendRow(["Erfasst am","Zeitraum von","Zeitraum bis","Maschine","Mitglied","Stundenzähler Beginn","Stundenzähler Ende","Gefahrene Stunden","Diesel Liter","Einsatzart","Stundensatz","Betrag","Getankt","Abgeschmiert","Bemerkung","Stunden seit letzter Abschmierung","Abschmierung fällig","Abschmierung ab 6h erforderlich"])}return sheet}
function findLastGreasedEnde(sheet){var lastRow=sheet.getLastRow();if(lastRow<2)return"";for(var row=lastRow;row>=2;row--){var abgeschmiert=String(sheet.getRange(row,14).getValue()).toLowerCase();if(abgeschmiert==="ja"||abgeschmiert==="true"||abgeschmiert==="x"){return toNumber(sheet.getRange(row,7).getValue())}}return""}
function doPost(e){var sheet=ensureSheet();var data=JSON.parse(e.postData.contents);var stundensatz=data.einsatzart==="ueberbetrieblich"?50:15;var start=toNumber(data.stundenStart);var ende=toNumber(data.stundenEnde);var gefahreneStunden=Math.round((ende-start)*100)/100;if(gefahreneStunden<0)gefahreneStunden=0;var diesel=toNumber(data.diesel);var betrag=Math.round(gefahreneStunden*stundensatz*100)/100;var lastGreasedEnde=findLastGreasedEnde(sheet);var stundenSeitLetzterAbschmierung="";var abschmierungFaellig="";var abschmierungErforderlich="";if(data.abgeschmiert){stundenSeitLetzterAbschmierung=0;abschmierungFaellig="Nein";abschmierungErforderlich="Nein"}else if(lastGreasedEnde!==""){stundenSeitLetzterAbschmierung=Math.round((ende-Number(lastGreasedEnde))*100)/100;if(stundenSeitLetzterAbschmierung<0)stundenSeitLetzterAbschmierung=0;abschmierungFaellig=stundenSeitLetzterAbschmierung>=8?"Ja":"Nein";abschmierungErforderlich=stundenSeitLetzterAbschmierung>=6?"Ja":"Nein"}sheet.appendRow([new Date(),data.datumVon||"",data.datumBis||"",data.maschine||"Bagger EZ80",data.mitglied||"",start,ende,gefahreneStunden,diesel,data.einsatzart==="ueberbetrieblich"?"überbetrieblich":"innerbetrieblich",stundensatz,betrag,data.getankt?"Ja":"Nein",data.abgeschmiert?"Ja":"Nein",data.bemerkung||"",stundenSeitLetzterAbschmierung,abschmierungFaellig,abschmierungErforderlich]);return ContentService.createTextOutput(JSON.stringify({ok:true})).setMimeType(ContentService.MimeType.JSON)}
function doGet(e){var action=e&&e.parameter?e.parameter.action:"";if(action==="last"){var sheet=ensureSheet();if(sheet.getLastRow()<2){return ContentService.createTextOutput(JSON.stringify({ok:true,lastEnde:"",lastGreasedEnde:"",hoursSinceGreased:"",greaseDue:false})).setMimeType(ContentService.MimeType.JSON)}var lastRow=sheet.getLastRow();var lastEnde=toNumber(sheet.getRange(lastRow,7).getValue());var lastGreasedEnde=findLastGreasedEnde(sheet);var hoursSinceGreased="";var greaseDue=false;if(lastGreasedEnde!==""){hoursSinceGreased=Math.round((lastEnde-Number(lastGreasedEnde))*100)/100;if(hoursSinceGreased<0)hoursSinceGreased=0;greaseDue=hoursSinceGreased>=8}return ContentService.createTextOutput(JSON.stringify({ok:true,lastEnde:lastEnde,lastGreasedEnde:lastGreasedEnde,hoursSinceGreased:hoursSinceGreased,greaseDue:greaseDue})).setMimeType(ContentService.MimeType.JSON)}return ContentService.createTextOutput("Bagger EZ80 Erfassung ist aktiv.").setMimeType(ContentService.MimeType.TEXT)}